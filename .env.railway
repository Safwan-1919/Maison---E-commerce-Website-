# Railway Environment Variables
# Set these in Railway dashboard → Variables tab

# Database (Railway will use /data/ directory for persistent storage)
DATABASE_URL="file:/data/custom.db"

# Auth
NEXTAUTH_SECRET="maison-production-secret-change-this-to-random-string"
NEXTAUTH_URL="https://your-app-name.up.railway.app"

# Node.js
NODE_ENV="production"
HOSTNAME="0.0.0.0"
